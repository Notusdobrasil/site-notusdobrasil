# Credenciais do Mailrelay
MAILRELAY_HOST=https://sua-conta.ipzmarketing.com
MAILRELAY_API_KEY=sua_api_key_aqui
MAILRELAY_GROUP_ID=1

PORT=3000
SMTP_HOST=smtp.seu-servidor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_usuario
SMTP_PASS=sua_senha

SENDGRID_API_KEY=SG.sua_chave_sendgrid_aqui

MAIL_FROM_NAME=Notus Vagas
MAIL_FROM_ADDR=marketing@notus.ind.br
MAIL_TO_CURRICULO=recursoshumanos@notus.ind.br
MAIL_TO_CONTATO=contato@notus.ind.br
MAIL_TO_GARANTIA=garantia@notus.ind.br

# Chave secreta para sessões (mude em produção)
SESSION_SECRET=sua-chave-secreta-aleatoria-aqui

# Configurações do SQL Server
SQL_SERVER=seu-servidor\\instancia
SQL_DATABASE_ACESSO=nome_do_banco
SQL_USERNAME=usuario
SQL_PASSWORD=senha

# Logo URL (opcional)
LOGO_URL=https://www.notus.ind.br/images/logo-notus-branco.png
